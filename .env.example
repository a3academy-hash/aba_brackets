# ABA Brackets — environment variables.
# Copy to .env.local for local dev. In Vercel, set these in Project Settings → Environment Variables.

# Admin auth — set this to a strong password. Used both as the login secret AND
# as the HMAC key for session cookies, so changing it logs everyone out.
ADMIN_PASSWORD=

# Vercel KV / Upstash Redis credentials.
# When you connect Vercel KV in the dashboard, these are populated automatically.
# If running standalone Upstash, the UPSTASH_* names work too — the app accepts either.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Without KV credentials, the app uses an in-memory fallback in dev (state lost
# on restart). In production, missing KV credentials cause an error at first read.
